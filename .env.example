# Copy to .env.local at the repo root and fill in values from your Supabase project.
# NEVER commit .env or .env.local.

# ─── Supabase ──────────────────────────────────────────────────
# Project ref: ojtudvezjvrcdqgbrnyc
NEXT_PUBLIC_SUPABASE_URL=https://ojtudvezjvrcdqgbrnyc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Direct Postgres connection (used by `pnpm db:seed` and migration tooling)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PW]@db.ojtudvezjvrcdqgbrnyc.supabase.co:5432/postgres

# ─── App URLs ──────────────────────────────────────────────────
# Web (front-end + admin) is on upstatehomecenter.com.
# Email (mail / replies) is still on upstatehomesales.com — see RESEND_FROM_EMAIL
# and EMAIL_INBOUND_DOMAIN below. The email migration is a separate cutover.
NEXT_PUBLIC_PUBLIC_URL=https://upstatehomecenter.com
NEXT_PUBLIC_ADMIN_URL=https://admin.upstatehomecenter.com

# ─── Outbound email (Resend) ───────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified Resend sending domain — see docs/email-setup.md
RESEND_FROM_EMAIL=hello@mail.upstatehomesales.com
# Where new-lead notifications are sent (the dealer's inbox)
LEAD_NOTIFY_EMAIL=

# ─── Inbound email (Cloudflare Email Routing → Worker) ─────────
# Subdomain managed by Cloudflare Email Routing. Outbound Reply-To becomes
# replies+{token}@<this> so customer replies route back to the right lead.
EMAIL_INBOUND_DOMAIN=replies.upstatehomesales.com
# Shared secret the Cloudflare Worker presents as `Authorization: Bearer …`
# on every POST to /api/webhooks/inbound-email. Set the SAME value via
# `wrangler secret put INBOUND_WEBHOOK_SECRET` in workers/inbound-email-router.
INBOUND_WEBHOOK_SECRET=

# ─── SMS (deferred until Week 5) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Analytics (deferred) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GA_ID=
