# Copy to .env.local at the repo root and fill in values from your Supabase project.
# NEVER commit .env or .env.local.

# ─── Supabase ──────────────────────────────────────────────────
# Project ref: ojtudvezjvrcdqgbrnyc
NEXT_PUBLIC_SUPABASE_URL=https://ojtudvezjvrcdqgbrnyc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Direct Postgres connection (used by `pnpm db:seed` and migration tooling)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PW]@db.ojtudvezjvrcdqgbrnyc.supabase.co:5432/postgres

# ─── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_PUBLIC_URL=https://upstatehomesales.com
NEXT_PUBLIC_ADMIN_URL=https://admin.upstatehomesales.com

# ─── Email (Resend) ────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender on the Resend domain (mail.upstatehomesales.com)
RESEND_FROM_EMAIL=hello@mail.upstatehomesales.com
# Inbound parse domain — Reply-To addresses are replies+{token}@<this>
EMAIL_INBOUND_DOMAIN=mail.upstatehomesales.com
# Where new-lead notifications are sent (the dealer's inbox)
LEAD_NOTIFY_EMAIL=

# ─── SMS (deferred until Week 5) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Analytics (deferred) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GA_ID=
