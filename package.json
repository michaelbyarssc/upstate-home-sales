{
  "name": "uhs",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:diff": "supabase db diff -f staging --linked",
    "db:push": "supabase db push --linked",
    "db:reset": "supabase db reset --linked",
    "db:seed": "supabase db reset --linked && psql \"$SUPABASE_DB_URL\" -f supabase/seed.sql"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "cheerio": "^1.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.11"
  }
}
